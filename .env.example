# gp-monitor Agent — Environment Variables
#
# Todas las variables son OPCIONALES. config.yaml tiene prioridad sobre .env.
# Copia este archivo a .env junto a config.yaml y edita lo que necesites.

# URL del backend gp-it
GP_MONITOR_API_URL=https://api.dev.gp.ssdevsolutions.com

# Token de enrollment (compartido por todos los nodos)
GP_MONITOR_ENROLLMENT_TOKEN=

# Identidad del nodo
GP_MONITOR_NAME=
GP_MONITOR_AGENCY=Matriz
GP_MONITOR_ENVIRONMENT=production

# Intervalo y timeouts
GP_MONITOR_HEARTBEAT_INTERVAL_SECONDS=60
GP_MONITOR_HTTP_TIMEOUT_SECONDS=15

# Logging
GP_MONITOR_LOG_LEVEL=INFO
GP_MONITOR_LOG_FILE=

# Persistencia local (uuid + api_key)
GP_MONITOR_STATE_DIR=C:/ProgramData/gp-monitor